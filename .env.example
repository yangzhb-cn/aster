# Aster 本地环境变量示例。
# 使用方式：
#   cp .env.example .env
#   编辑 .env，把需要的密钥和值填进去。
#
# 不要把真实 .env 提交到 Git。

# 默认模型供应商是 DeepSeek。至少需要填写一个模型 API Key。
DEEPSEEK_API_KEY=

# 如果要切换到其他 OpenAI-compatible 供应商，取消下面几行注释并填写。
# OPENAI_COMPATIBLE_PROVIDER=deepseek
# OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=deepseek-v4-flash

# Web Chat 配置。aster2web 脚本默认会使用 8081。
ASTER_WEB_PORT=8081
ASTER_SESSION=default

# Telegram IM 配置。TELEGRAM_ALLOWED_CHAT_IDS 支持逗号分隔多个 chatId。
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# 如果只配置 OWNER_ID，aster2im 会把它当作 TELEGRAM_ALLOWED_CHAT_IDS 使用。
# OWNER_ID=

# Tavily Web Search API Key；只有调用 web_search 工具时才需要。
TAVILY_API_KEY=

# 后台任务扫描间隔，单位秒。默认 10。
SCHEDULE_INTERVAL_SECONDS=10
